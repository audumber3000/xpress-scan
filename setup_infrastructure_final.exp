#!/usr/bin/expect -f
set timeout 30

set public_server "89.167.103.199"
set private_server "10.0.0.2"
set private_pass "wEH3Krr3LFwtVvCLdUL7"
set new_pass "Prashant@135"

set pubkey "ssh-rsa  audii3000@Audumbers-MacBook-Pro.local"

# 1. Connect to Public Server
spawn ssh -o StrictHostKeyChecking=no root@$public_server
expect "root@*~#"

# 2. Try to SSH to Private Server
send "ssh -o StrictHostKeyChecking=no root@$private_server\r"
expect {
    "password:" {
        send "$private_pass\r"
        expect {
            "Current password:" {
                send "$private_pass\r"
                expect "New password:"
                send "$new_pass\r"
                expect "Retype new password:"
                send "$new_pass\r"
                exp_continue
            }
            "root@*~#" {
                send "passwd\r"
                expect "New password:"
                send "$new_pass\r"
                expect "Retype new password:"
                send "$new_pass\r"
                expect "password updated successfully"
            }
        }
    }
}

# 3. Finalize SSH Key on Private Server
expect "root@*~#"
send "mkdir -p ~/.ssh && chmod 700 ~/.ssh\r"
expect "root@*~#"
send "echo '$pubkey' >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys\r"
expect "root@*~#"

# 4. Set Gateway & Verify Internet
send "ip route del default || true; ip route add default via 10.0.0.3; echo \"nameserver 8.8.8.8\" > /etc/resolv.conf; ping -c 2 google.com\r"
expect "root@*~#"

send "exit\r"
expect "root@*~#"
send "exit\r"
expect eof
