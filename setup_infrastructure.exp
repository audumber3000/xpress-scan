#!/usr/bin/expect -f
set timeout 30

# Variables for Public Server
set public_server "89.167.103.199"
set public_pass "u3JNVbTCA9ae"
set new_pass "Prashant@135"

# SSH Key content
set pubkey "ssh-rsa  audii3000@Audumbers-MacBook-Pro.local"

# 1. Connect to Public Server
spawn ssh -o StrictHostKeyChecking=no root@$public_server
expect {
    "password:" {
        send "$public_pass\r"
        expect {
            "Current password:" {
                send "$public_pass\r"
                expect "New password:"
                send "$new_pass\r"
                expect "Retype new password:"
                send "$new_pass\r"
                exp_continue
            }
            "root@*~#" {
                send "passwd\r"
                expect "New password:"
                send "$new_pass\r"
                expect "Retype new password:"
                send "$new_pass\r"
                expect -re {passwd: password updated successfully|passwd: all authentication tokens updated successfully}
            }
        }
    }
    "root@*~#" {
        send "echo 'Already authenticated via key'\r"
    }
}

# 2. Add our SSH Key to Public Server
expect "root@*~#"
send "mkdir -p ~/.ssh && chmod 700 ~/.ssh\r"
expect "root@*~#"
send "echo '$pubkey' >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys\r"
expect "root@*~#"

# 3. Connect to Private DB Server from Public Server
set private_server "10.0.0.2"
set private_pass "vrwxwUncxwXk"

send "ssh -o StrictHostKeyChecking=no root@$private_server\r"
expect {
    "password:" {
        send "$private_pass\r"
        expect {
            "Current password:" {
                send "$private_pass\r"
                expect "New password:"
                send "$new_pass\r"
                expect "Retype new password:"
                send "$new_pass\r"
                exp_continue
            }
            "root@*~#" {
                send "passwd\r"
                expect "New password:"
                send "$new_pass\r"
                expect "Retype new password:"
                send "$new_pass\r"
                expect -re {passwd: password updated successfully|passwd: all authentication tokens updated successfully}
            }
        }
    }
    "root@*~#" {
        send "echo 'Already established jump link'\r"
    }
}

# 4. Add SSH Key inside the DB server so we can instantly access it too
expect "root@*~#"
send "mkdir -p ~/.ssh && chmod 700 ~/.ssh\r"
expect "root@*~#"
send "echo '$pubkey' >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys\r"
expect "root@*~#"
send "exit\r"
expect "root@*~#"
send "exit\r"
expect eof
