#!/usr/bin/expect -f
set timeout 30

# Variables for Public Backend Server
set server "89.167.103.199"
set user "root"
set oldpass "etxfrcLeqNJ4EcfLhRCd"
set newpass "Prashant@135"

# SSH Key content
set pubkey "ssh-rsa  audii3000@Audumbers-MacBook-Pro.local"

# Remove old host key locally just in case
system "ssh-keygen -R $server"

spawn ssh -o StrictHostKeyChecking=no $user@$server
expect {
    "password:" {
        send "$oldpass\r"
        expect {
            "Current password:" {
                send "$oldpass\r"
                expect "New password:"
                send "$newpass\r"
                expect "Retype new password:"
                send "$newpass\r"
                exp_continue
            }
            "root@*~#" {
                send "passwd\r"
                expect "New password:"
                send "$newpass\r"
                expect "Retype new password:"
                send "$newpass\r"
                expect -re {passwd: password updated successfully|passwd: all authentication tokens updated successfully}
            }
        }
    }
}

# 2. Inject SSH Key and Prepare for NAT
expect "root@*~#"
send "mkdir -p ~/.ssh && chmod 700 ~/.ssh\r"
expect "root@*~#"
send "echo '$pubkey' >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys\r"
expect "root@*~#"
send "sysctl -w net.ipv4.ip_forward=1 && iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE\r"
expect "root@*~#"

send "exit\r"
expect eof
