#!/usr/bin/expect -f
set timeout 30

# Public server is already set up with SSH key, so we can just hop in.
set public_server "89.167.103.199"

# Private DB server variables
set private_server "10.0.0.2"
set private_pass "WtNUE9iptMqE"
set new_pass "Prashant@135"

# SSH Key content (same as before)
set pubkey "ssh-rsa  audii3000@Audumbers-MacBook-Pro.local"

# 1. Connect to Public Server (should use key)
spawn ssh -o StrictHostKeyChecking=no root@$public_server
expect "root@*~#"

# 2. Add local SSH key for easier hopping from Mac -> Public -> Private
send "mkdir -p ~/.ssh && chmod 700 ~/.ssh\r"
expect "root@*~#"
send "echo '$pubkey' >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys\r"
expect "root@*~#"

# 3. Jump to Private DB Server
send "ssh -o StrictHostKeyChecking=no root@$private_server\r"
expect {
    "password:" {
        send "$private_pass\r"
        expect {
            "Current password:" {
                send "$private_pass\r"
                expect "New password:"
                send "$new_pass\r"
                expect "Retype new password:"
                send "$new_pass\r"
                exp_continue
            }
            "root@*~#" {
                send "passwd\r"
                expect "New password:"
                send "$new_pass\r"
                expect "Retype new password:"
                send "$new_pass\r"
                expect "password updated successfully"
            }
        }
    }
}

# 4. Inject SSH key into DB server
expect "root@*~#"
send "mkdir -p ~/.ssh && chmod 700 ~/.ssh\r"
expect "root@*~#"
send "echo '$pubkey' >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys\r"
expect "root@*~#"

# 5. Check outbound connectivity on DB server while we are there
send "ping -c 2 google.com\r"
expect {
    "2 packets transmitted, 2 received" {
        send "echo 'DB_HAS_INTERNET=true' > /tmp/net_status\r"
    }
    "Network is unreachable" {
        send "echo 'DB_HAS_INTERNET=false' > /tmp/net_status\r"
    }
}
expect "root@*~#"

send "exit\r"
expect "root@*~#"
send "exit\r"
expect eof
