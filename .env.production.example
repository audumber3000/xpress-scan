# ─────────────────────────────────────────────────────────────────────────────
#  MolarPlus — Production Environment Template
#  Copy this file to .env.production and fill in all values before deploying.
#  NEVER commit .env.production to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
POSTGRES_DB=molarplus

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_STRING

# ── Firebase ──────────────────────────────────────────────────────────────────
# Absolute path to the firebase JSON file ON THE SERVER DISK
# e.g. upload it with: scp firebase.json root@<server>:/opt/molarplus/firebase.json
FIREBASE_JSON_PATH=/opt/molarplus/firebase-service-account.json

# ── Cloudflare R2 Storage ─────────────────────────────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET_NAME=

# ── Server URLs ───────────────────────────────────────────────────────────────
# Replace with your server's public IP or domain name
BACKEND_URL=http://<SERVER_IP_OR_DOMAIN>:8000
FRONTEND_URL=https://app.molarplus.com
NEXUS_SERVICES_URL=http://<SERVER_IP_OR_DOMAIN>:8001

# ── Cashfree Payments (Production) ────────────────────────────────────────────
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=production
SUBSCRIPTION_PROVIDER=cashfree
CASHFREE_RETURN_URL=https://app.molarplus.com/subscription
CASHFREE_NOTIFY_URL=http://<SERVER_IP_OR_DOMAIN>:8000/api/v1/subscriptions/webhook/cashfree

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_API_VERSION=v19.0

# ── Email (ZeptoMail) ─────────────────────────────────────────────────────────
ZEPTO_MAIL_TOKEN=
ZEPTO_API_URL=https://api.zeptomail.in/v1.1/email
ZEPTO_PLATFORM_FROM_EMAIL=clinic@molarplus.com
ZEPTO_PLATFORM_FROM_NAME=MolarPlus
ZEPTO_PATIENT_FROM_EMAIL=care@molarplus.com
ZEPTO_PATIENT_FROM_NAME=MolarPlus Care
ZEPTO_FROM_EMAIL=clinic@molarplus.com
ZEPTO_FROM_NAME=MolarPlus

# ── WhatsApp Template Names ───────────────────────────────────────────────────
WA_TPL_APPOINTMENT_BOOKED=mp_appointment_booked
WA_TPL_APPOINTMENT_CONFIRMED=mp_appointment_confirmed
WA_TPL_CHECKED_IN=mp_checked_in
WA_TPL_APPOINTMENT_REMINDER=mp_appointment_reminder
WA_TPL_INVOICE=mp_invoice_sent
WA_TPL_PRESCRIPTION=mp_prescription_sent
WA_TPL_CONSENT_FORM=mp_consent_form
WA_TPL_GOOGLE_REVIEW=mp_google_review

# ── SMS (MSG91) ───────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SMS_SENDER=MOLARPLUS

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Google ────────────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
