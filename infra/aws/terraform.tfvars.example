# Copy to terraform.tfvars (gitignored) and fill in. Or use TF_VAR_* env vars.

key_name          = "molarplus-ec2"            # an EC2 key pair you created in ap-south-1
allowed_ssh_cidrs = ["YOUR.PUBLIC.IP.HERE/32"] # your IP only — not 0.0.0.0/0
db_password       = "set-a-strong-password"    # also goes into DATABASE_URL (encode '@' as %40)

# Optional overrides:
# instance_type     = "t3.large"
# db_instance_class = "db.t3.small"
