{
  "name": "molarplus",
  "version": "3.13.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "fix-adaptive-icon": "node scripts/fix-adaptive-icon.js",
    "test": "jest",
    "preflight": "node scripts/preflight.js",
    "release:android": "npm run preflight && npm test && cd android && ./gradlew bundleRelease"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|lucide-react-native)"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-navigation/bottom-tabs": "^7.9.0",
    "@react-navigation/native": "^7.1.26",
    "@react-navigation/native-stack": "^7.9.0",
    "cashfree-pg-api-contract": "^2.1.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.32",
    "expo-auth-session": "^7.0.10",
    "expo-constants": "^18.0.13",
    "expo-device": "^8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-network": "~8.0.8",
    "expo-notifications": "^0.32.16",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "^15.0.10",
    "firebase": "^12.7.0",
    "lucide-react-native": "^0.562.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1313.0",
    "react-native-cashfree-pg-sdk": "^2.3.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0"
  },
  "private": true,
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "^19.2.8",
    "babel-preset-expo": "~54.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.15",
    "react-refresh": "^0.18.0",
    "react-test-renderer": "^19.1.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  }
}
